# REQUIRES: host-cc

# RUN: split-file %s %t
# RUN: basic09c --compile --cc %cc -o %t/onerror %t/onerror.b09
# RUN: %t/onerror | FileCheck %s

# CHECK: TRAPPED OPEN FAILURE
# CHECK-NEXT: TRAPPED SHELL FAILURE
# CHECK-NEXT: SHELL SUCCESS FALLTHROUGH
# CHECK-NEXT: AFTER SUCCESSFUL SHELL
# CHECK-NEXT: NO TRAP ARMED, CONTINUES
# CHECK-NEXT: STILL CONTINUES AFTER UNTRAPPED OPEN FAILURE

#--- onerror.b09
PROCEDURE onerror
DIM path:INTEGER

ON ERROR GOTO 100
OPEN #path,"/nonexistent/dir/nofile.dat":READ
PRINT "SHOULD NOT REACH HERE"
100    ON ERROR
PRINT "TRAPPED OPEN FAILURE"

ON ERROR GOTO 200
SHELL "false"
PRINT "SHOULD NOT REACH HERE EITHER"
200    ON ERROR
PRINT "TRAPPED SHELL FAILURE"

ON ERROR GOTO 300
SHELL "true"
PRINT "SHELL SUCCESS FALLTHROUGH"
300    ON ERROR
PRINT "AFTER SUCCESSFUL SHELL"

SHELL "false"
PRINT "NO TRAP ARMED, CONTINUES"
OPEN #path,"/nonexistent/dir/x.dat":READ
PRINT "STILL CONTINUES AFTER UNTRAPPED OPEN FAILURE"

END
