# REQUIRES: host-cc
# REQUIRES: sdl2

# RUN: split-file %s %t
# RUN: not basic09c --compile --cc %cc -o %t/no-sdl %t/sdl.b09 2>&1 | FileCheck %s --check-prefix=NO-SDL
# RUN: basic09c --compile --sdl --cc %cc -o %t/sdl %t/sdl.b09
