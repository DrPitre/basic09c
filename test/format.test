# RUN: split-file %s %t
# RUN: basic09c --format %t/messy.b09 | FileCheck %s

# CHECK: PROCEDURE DEMO
# CHECK-NEXT:   DIM X, Y: INTEGER
# CHECK-NEXT:   X := 1
# CHECK-NEXT:   IF X > 0 THEN
# CHECK-NEXT:     Y := X + 1
# CHECK-NEXT:   ELSE
# CHECK-NEXT:     Y := 0
# CHECK-NEXT:   ENDIF
# CHECK-NEXT:   FOR X := 1 TO 3
# CHECK-NEXT:     PRINT X;Y
# CHECK-NEXT:   NEXT X
# CHECK-NEXT: LN100:
# CHECK-NEXT:   PRINT "done"
# CHECK-NEXT: END

#--- messy.b09
procedure demo
dim x,y:integer
x:=1
if x>0 then
y:=x+1
else
y:=0
endif
for x:=1 to 3
print x;y
next x
100 print "done"
end
