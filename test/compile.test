# REQUIRES: host-cc

# RUN: split-file %s %t
# RUN: basic09c --compile --cc %cc -o %t/hello %t/hello.b09
# RUN: %t/hello | FileCheck %s
# RUN: basic09c --compile --cc %cc -o %t/input %t/input.b09
# RUN: printf '42\n' | %t/input | FileCheck %s --check-prefix=INPUT
# RUN: basic09c --compile --cc %cc -o %t/fix %t/fix.b09
# RUN: %t/fix | FileCheck %s --check-prefix=FIX
# RUN: basic09c --compile --cc %cc -o %t/percent %t/percent.b09
# RUN: %t/percent | FileCheck %s --check-prefix=PERCENT
# RUN: basic09c --compile --cc %cc -o %t/using %t/using.b09
# RUN: %t/using | FileCheck %s --check-prefix=USING
# RUN: not basic09c --compile --cc %cc %t/hello.b09 2>&1 | FileCheck %s --check-prefix=NOOUTPUT

# CHECK: Hello from compile mode
# CHECK-NEXT: 42

# INPUT: Value: ? 42

# FIX: 3
# FIX-NEXT: 0

# PERCENT: APR: 5 %
# PERCENT-NEXT: Term: 5 years

# USING: APR: 5 %
# USING-NEXT: Term: 5 years
# USING-NEXT: Money: 123.46
# USING-NEXT: Principal:  50000.00

# NOOUTPUT: error: --compile requires -o <output>

#--- hello.b09
PROCEDURE hello
DIM x:INTEGER
x:=42
PRINT "Hello from compile mode"
PRINT x
END

#--- input.b09
PROCEDURE inputdemo
DIM x:INTEGER
PRINT "Value: ";
INPUT x
PRINT x
END

#--- fix.b09
PROCEDURE fixdemo
PRINT FIX(3.6)
PRINT FIX(.02*100)/100
END

#--- percent.b09
PROCEDURE percentdemo
PRINT "APR: ";5;"%"
PRINT "Term: ";5;" years"
END

#--- using.b09
PROCEDURE usingdemo
PRINT USING "'APR: ',R1,' %'",5
PRINT USING "'Term: ',I1,' years'",5
PRINT USING "'Money: ',R8.2",123.456
PRINT USING "'Principal: ',R12.2",50000.0
END
