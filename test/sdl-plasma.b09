PROCEDURE sdlplasma
DIM w,h,scale:INTEGER
DIM px,py,t,v,color,key,quit,frame:INTEGER
DIM fx,fy,ft,s1,s2,s3,s4,sum:REAL

w:=320
h:=200
scale:=4
frame:=0

RUN sdl("open",w,h)

REPEAT
  ft:=frame*0.10

  FOR py:=0 TO h/scale-1
    FOR px:=0 TO w/scale-1
      fx:=px
      fy:=py

      s1:=SIN(fx/8+ft)
      s2:=SIN(fy/6-ft*1.3)
      s3:=SIN((fx+fy)/10+ft*0.7)
      s4:=SIN(SQR((fx-20)*(fx-20)+(fy-12)*(fy-12))/4-ft*2)

      sum:=s1+s2+s3+s4
      v:=INT((sum+4)*15/8)
      color:=1+MOD(v,15)

      RUN sdl("fillbox",px*scale,py*scale,scale,scale,color)
    NEXT px
  NEXT py

  RUN sdl("present")
  RUN sdl("poll")
  quit:=sdl("quit")
  key:=sdl("key")
  frame:=frame+1
UNTIL quit<>0 OR key=27

RUN sdl("close")
END
