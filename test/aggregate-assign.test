# REQUIRES: host-cc

# RUN: split-file %s %t
# RUN: basic09c --compile --cc %cc -o %t/aggassign %t/aggassign.b09
# RUN: %t/aggassign | FileCheck %s
# RUN: not basic09c --compile --cc %cc -o %t/badrhs %t/badrhs.b09 2>&1 | FileCheck %s --check-prefix=BADRHS
# RUN: not basic09c --compile --cc %cc -o %t/mismatch %t/mismatch.b09 2>&1 | FileCheck %s --check-prefix=MISMATCH

# CHECK: 10
# CHECK-NEXT: 20
# CHECK-NEXT: 30
# CHECK-NEXT: 40
# CHECK-NEXT: 1
# CHECK-NEXT: 100
# CHECK-NEXT: 200
# CHECK-NEXT: 0
# CHECK-NEXT: 25
# CHECK-NEXT: 50
# CHECK-NEXT: 75
# CHECK-NEXT: 100

# BADRHS: array assignment requires a variable on the right-hand side

# MISMATCH: type mismatch in record assignment

#--- aggassign.b09
PROCEDURE aggassign
TYPE point=x:INTEGER; y:INTEGER
TYPE widget=id:INTEGER; origin:point; samples(4):BYTE
DIM a(3),b(3):INTEGER
DIM w,v:widget
DIM i:INTEGER

FOR i:=0 TO 3
a(i):=(i+1)*10
NEXT i
b:=a
FOR i:=0 TO 3
PRINT b(i)
NEXT i

w.id:=1
w.origin.x:=100
w.origin.y:=200
FOR i:=0 TO 4
w.samples(i):=i*25
NEXT i
v:=w
PRINT v.id
PRINT v.origin.x
PRINT v.origin.y
FOR i:=0 TO 4
PRINT v.samples(i)
NEXT i

END

#--- badrhs.b09
PROCEDURE badrhs
DIM a(3):INTEGER
a:=5
END

#--- mismatch.b09
PROCEDURE mismatch
TYPE point=x:INTEGER; y:INTEGER
TYPE point3=x:INTEGER; y:INTEGER; z:INTEGER
DIM p:point
DIM p3:point3
p:=p3
END
